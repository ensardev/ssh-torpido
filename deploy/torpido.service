[Unit]
Description=torpido — battleship over SSH
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=torpido
Group=torpido
WorkingDirectory=/opt/torpido
EnvironmentFile=/etc/torpido.env
ExecStart=/opt/torpido/torpido serve
Restart=always
RestartSec=3
# Allow binding to port 22 (<1024) without running as root.
AmbientCapabilities=CAP_NET_BIND_SERVICE
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
